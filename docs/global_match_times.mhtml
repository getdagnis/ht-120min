.prettytable th, .prettytable td { border: 1px solid rgb(170, 170, 170); pa=
dding: 0.2em; }

.prettytable th { background: rgb(242, 242, 242); text-align: center; }

.prettytable caption { font-weight: bold; }

.infobox { border: 1px solid rgb(170, 170, 170); background-color: rgb(249,=
 249, 249); color: black; margin: 0.5em 0px 0.5em 1em; padding: 0.2em; floa=
t: right; clear: right; }

.infobox td, .infobox th { vertical-align: top; }

.infobox caption { font-size: larger; }

.infobox.bordered { border-collapse: collapse; }

.infobox.bordered td, .infobox.bordered th { border: 1px solid rgb(170, 170=
, 170); }

.infobox.bordered .borderless td, .infobox.bordered .borderless th { border=
: 0px; }

.infobox.sisterproject { width: 20em; font-size: 90%; }

.infobox.standard-talk { border: 1px solid rgb(192, 192, 144); background-c=
olor: rgb(248, 234, 186); }

.infobox.standard-talk.bordered td, .infobox.standard-talk.bordered th { bo=
rder: 1px solid rgb(192, 192, 144); }

.infobox.bordered .mergedtoprow td, .infobox.bordered .mergedtoprow th { bo=
rder-width: 1px 1px 0px 0px; border-style: solid solid none none; border-co=
lor: rgb(170, 170, 170) rgb(170, 170, 170) currentcolor currentcolor; borde=
r-image: initial; }

.infobox.bordered .mergedrow td, .infobox.bordered .mergedrow th { border-w=
idth: 0px 1px 0px 0px; border-style: none solid none none; border-color: cu=
rrentcolor rgb(170, 170, 170) currentcolor currentcolor; border-image: init=
ial; }

.navigation-menu { overflow: hidden; background-color: rgb(46, 111, 64); fo=
nt-family: Arial; border-radius: 10px; }

.navigation-menu a { float: left; font-size: 16px; color: white; text-align=
: center; padding: 14px 16px; text-decoration: none; }

.navigation-dropdown { float: left; overflow: hidden; }

.navigation-dropdown .dropdown-button { font-size: 16px; border-width: medi=
um; border-style: none; border-color: currentcolor; border-image: initial; =
outline: none; color: white; padding: 14px 16px; background-color: inherit;=
 font-family: inherit; margin: 0px; }

.dropdown-content { display: none; position: absolute; background-color: rg=
b(46, 111, 64); min-width: 160px; box-shadow: rgba(0, 0, 0, 0.2) 0px 8px 16=
px 0px; z-index: 1; }

.dropdown-button a { float: none; }

.dropdown-content a { float: none; color: white; padding: 12px 16px; text-d=
ecoration: none; display: block; text-align: left; }

.navigation-dropdown:hover .dropdown-content { display: block; }
