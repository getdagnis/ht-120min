All containers/elements for the selected version and action type are shown.
<?xml version="1.0" encoding="utf-8"?>
-<HattrickData>
<UserSupporterTier> : supporterTier
Indicates which Supporter package the fetching user has, or empty if not a Supporter.
</UserSupporterTier>
-<Player>
<PlayerID> : unsigned Integer
The globally unique playerID.
</PlayerID>
<FirstName> : String
Player's FirstName name.
</FirstName>
<NickName> : String
Player's NickName name.
</NickName>
<LastName> : String
Player's LastName name.
</LastName>
<PlayerNumber> : unsigned Integer
The number (1 to 99) that the owner of the team has assigned this player.
</PlayerNumber>
<PlayerCategoryID> : PlayerCategoryID
The CategoryID assigned by the owner. Only visible to owner.
</PlayerCategoryID>
<OwnerNotes> : String (HTML encoded)
The notes owner has set. Only visible to owner.
</OwnerNotes>
<Age> : unsigned Integer
The age of the player in years.
</Age>
<AgeDays> : unsigned Integer
The amount of days past since last birthday.
</AgeDays>
<NextBirthDay> : DateTime
The aproximate Date/time of next birthday.
</NextBirthDay>
<GenderID> : GenderID
The gender of the player
</GenderID>
<ArrivalDate> : DateTime
The date of arrival to the team.
</ArrivalDate>
<PlayerForm> : SkillLevel
The current form, given as an integer with 1 indicating disastrous, 2 for wretched and so on.
</PlayerForm>
<Cards> : unsigned Integer
The number of currently accumulated cards. If the player is suspended, this will return 3 (whether the player has actually accumulated 3 bookings, or if he has become suspended by being sent off after 2 bookings in the same game). If a match is running this value is not available
</Cards>
<InjuryLevel> : Integer
The number of weeks the player is predicted to be injured. If the player is bruised, a value of 0 is returned. If the player is healthy, a value of -1 is returned. If a match is running this value is not available
</InjuryLevel>
<Statement> : String (HTML encoded)
If the owner is a HT Supporter, he may have provided a Statement from his players.
</Statement>
<PlayerLanguage> : String<!-- This elements is only shown if the user has supporter -->
The language the player speaks in his Statement, if existing.
</PlayerLanguage>
<PlayerLanguageID> : unsigned Integer<!-- This elements is only shown if the user has supporter -->
The languageID the player speaks in his Statement, if existing.
</PlayerLanguageID>
-<TrainerData>
<TrainerType> : unsigned Integer
0 = defensive, 1 = offensive, 2 = balanced
</TrainerType>
<TrainerSkillLevel> : unsigned Integer
The trainer skill level, from 1 (lowest) to 5 (highest).
</TrainerSkillLevel>
</TrainerData>
<Agreeability> : PlayerAgreeability
The agreeability of the player.
</Agreeability>
<Aggressiveness> : PlayerAggressiveness
The aggressiveness of the player.
</Aggressiveness>
<Honesty> : PlayerHonesty
The honesty of the player.
</Honesty>
<Experience> : SkillLevel
The experience of the player.
</Experience>
<Loyalty> : SkillLevel
The loyalty of the player.
</Loyalty>
<MotherClubBonus> : Boolean
Whether the player gains the mother club bonus.
</MotherClubBonus>
-<MotherClub>
<TeamID> : unsigned Integer
The globally unique TeamID of the mother club of the player.
</TeamID>
<TeamName> : String
The full team name of the mother club of the player.
</TeamName>
</MotherClub>
<Leadership> : SkillLevel
The leadership of the player.
</Leadership>
<Specialty> : SpecialtyID
Integer indicating the specialty (if any) of the player.
</Specialty>
<NativeCountryID> : unsigned Integer
CountryID of the country where the player was born.
</NativeCountryID>
<NativeLeagueID> : unsigned Integer
LeagueID of the league where the player was born.
</NativeLeagueID>
<NativeLeagueName> : String
LeagueName of the league where the player was born.
</NativeLeagueName>
<TSI> : unsigned Integer
The Total Skill Index (TSI) of the player.
</TSI>
-<OwningTeam>
<TeamID> : unsigned Integer
The globally unique TeamID of the team owning the player.
</TeamID>
<TeamName> : String
The full team name of the team owning the player.
</TeamName>
<LeagueID> : unsigned Integer
LeagueID for the league of the team owning the player.
</LeagueID>
</OwningTeam>
<Salary> : Money
The salary of the player. The container is empty If the player has no owner.
</Salary>
<IsAbroad> : Boolean*
The abroad status of the player, given as an integer. true for beeing in home country, false for beeing in a team abroad. The container is empty If the player has no owner.
</IsAbroad>
-<PlayerSkills>
<StaminaSkill> : SkillLevel
The stamina skill of the player.
</StaminaSkill>
<KeeperSkill> : SkillLevel
The keeper skill of the player.
</KeeperSkill>
<PlaymakerSkill> : SkillLevel
The playmaker skill of the player.
</PlaymakerSkill>
<ScorerSkill> : SkillLevel
The scorer skill of the player.
</ScorerSkill>
<PassingSkill> : SkillLevel
The passing skill of the player.
</PassingSkill>
<WingerSkill> : SkillLevel
The winger skill of the player.
</WingerSkill>
<DefenderSkill> : SkillLevel
The defender skill of the player.
</DefenderSkill>
<SetPiecesSkill> : SkillLevel
The set pieces skill of the player.
</SetPiecesSkill>
</PlayerSkills>
<Caps> : unsigned Integer
The number of matches played for the national team.
</Caps>
<CapsU20> : unsigned Integer
The number of matches played for the U-20 national team.
</CapsU20>
<CareerGoals> : unsigned Integer
The total number of goals throughout this player's carreer. If a match is running this value is not available
</CareerGoals>
<CareerHattricks> : unsigned Integer
The total number of hattricks throughout this player's carreer. If a match is running this value is not available
</CareerHattricks>
<LeagueGoals> : unsigned Integer
The number of goals in the league this season. If a match is running this value is not available
</LeagueGoals>
<CupGoals Available='Boolean'> : unsigned Integer
The number of goals in the cup this season.
</CupGoals>
<FriendliesGoals> : unsigned Integer
The number of goals in friendlies this season. If a match is running this value is not available
</FriendliesGoals>
<MatchesCurrentTeam> : unsigned Integer
The total number of matches for current team. If a match is running this value is not available
</MatchesCurrentTeam>
<GoalsCurrentTeam> : unsigned Integer
The number of goals in friendlies this season. If a match is running this value is not available
</GoalsCurrentTeam>
<AssistsCurrentTeam> : unsigned Integer
The number of assists for the current team.
</AssistsCurrentTeam>
<CareerAssists> : unsigned Integer
The number of assists through out the whole player's career
</CareerAssists>
<NationalTeamID> : unsigned Integer*
If the player is enrolled on a national team, this is that national team's ID.
</NationalTeamID>
<NationalTeamName> : String*
If the player is enrolled on a national team, this is that national team's name.
</NationalTeamName>
<TransferListed> : Boolean
Is the player on transfer list?
</TransferListed>
-<TransferDetails>
<AskingPrice> : Money
The original asking price.
</AskingPrice>
<Deadline> : DateTime
The transfer deadline. Can be even a few hours in the past.
</Deadline>
<HighestBid> : Money
The highest bid made for the player so far. Returns 0 if no bids have been made.
</HighestBid>
<MaxBid> : Money
The maximum bid (autobid) set by the user. Not shown if not set.
</MaxBid>
-<BidderTeam>
<TeamID> : unsigned Integer
The globally unique TeamID.
</TeamID>
<TeamName> : String
The full team name.
</TeamName>
</BidderTeam>
</TransferDetails>
-<LastMatch>
<Date> : DateTime
Date of last played match.
</Date>
<MatchId> : unsigned Integer
Id of the last played match.
</MatchId>
<PositionCode> : MatchRoleID
Played position in the last match.
</PositionCode>
<PlayedMinutes> : unsigned Integer
Minutes played in the last match.
</PlayedMinutes>
<Rating> : Float
The players average rating in the game.
</Rating>
<RatingEndOfGame> : Float
The players rating at the end of the game.
</RatingEndOfGame>
</LastMatch>
</Player>
</HattrickData>