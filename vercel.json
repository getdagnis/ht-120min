{
  "rewrites": [
    {
      "source": "/testing",
      "destination": "/api/testing"
    },
    {
      "source": "/testing/:path*",
      "destination": "/api/testing/:path*"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ],
      "destination": "/index.html"
    }
  ]
}
